{
  "name": "clouddeploymentframework",
  "displayName": "CloudDeploymentFramework",
  "description": "CloudDeploymentFramework extension",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.77.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sample-container",
          "title": "CloudDeploymentFramework",
          "icon": "./resources/deployment-framework-icon.svg"
        }
      ]
    },
    "views": {
      "sample-container": [
        {
          "id": "sampleTreeView",
          "name": "Sample Tree View",
          "icon": "./resources/deployment-framework-icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^6.0.2",
    "ts-loader": "^9.5.7",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "@vscode/test-electron": "^2.5.2"
  }
}